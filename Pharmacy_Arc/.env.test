# Test environment configuration for E2E tests
# This file is used for local test runs only

# Flask Configuration
FLASK_SECRET_KEY=test-secret-key-for-local-testing-minimum-32-characters-long
FLASK_PORT=5013
FLASK_DEBUG=false

# Supabase Configuration (use test database if available)
# For real testing, replace with actual test database credentials
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_KEY=your-test-supabase-anon-key-here

# Emergency Admin Accounts (test passwords)
# Password for both: "password" (for testing only)
EMERGENCY_ADMIN_SUPER=super:$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewY5NU7hlZiOXE4u
EMERGENCY_ADMIN_BASIC=admin:$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewY5NU7hlZiOXE4u

# Security Settings
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
REQUIRE_HTTPS=false

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_ROTATION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=pharmacy_app_test.log

# Pharmacy Auditor — Environment Configuration
# Copy to .env and fill in your actual values:  cp .env.example .env
# DO NOT commit .env to version control!

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a key:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=generate-a-strong-random-secret-key-here-minimum-32-characters
FLASK_PORT=5013
FLASK_DEBUG=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key-here
# Service role key — bypasses RLS. Required for photo uploads + user management.
# Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ── Emergency Admin Accounts ──────────────────────────────────────────────────
# Format: username:bcrypt_hash
# Generate a hash:  python -c "from security import PasswordHasher; print(PasswordHasher().hash_password('YOUR_PASSWORD'))"
EMERGENCY_ADMIN_SUPER=super:$2b$12$EXAMPLE_HASH_REPLACE_ME
EMERGENCY_ADMIN_BASIC=admin:$2b$12$EXAMPLE_HASH_REPLACE_ME

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
# Set to true on Railway/production (enables HSTS + secure cookies)
REQUIRE_HTTPS=false

# ── Telegram Bot (optional — for OCR Z Report submission) ─────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-token-from-botfather
# Secret token for webhook verification (any random string, must match setWebhook call)
TELEGRAM_WEBHOOK_SECRET=
# Google API key for OCR (Gemini 3 Pro) and AI chat (Gemini 2.5 Flash)
GOOGLE_API_KEY=your-google-api-key

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_ROTATION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=pharmacy_app.log

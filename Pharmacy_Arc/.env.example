# Pharmacy Management System - Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Flask Configuration
FLASK_SECRET_KEY=generate-a-strong-random-secret-key-here-minimum-32-characters
FLASK_PORT=5013
FLASK_DEBUG=false

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key-here

# Emergency Admin Accounts (Hashed passwords - use admin CLI to generate)
# Format: username:bcrypt_hash
EMERGENCY_ADMIN_SUPER=super:$2b$12$EXAMPLE_HASH_REPLACE_ME
EMERGENCY_ADMIN_BASIC=admin:$2b$12$EXAMPLE_HASH_REPLACE_ME

# Security Settings
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
REQUIRE_HTTPS=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_ROTATION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=pharmacy_app.log
